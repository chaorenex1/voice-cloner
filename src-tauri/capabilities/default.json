{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the FunSpeech-based voice-cloner app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:app:default",
    "core:app:allow-name",
    "core:app:allow-version",
    "core:app:allow-tauri-version",
    "dialog:default"
  ]
}
