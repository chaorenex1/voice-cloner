{
  "name": "voice-cloner",
  "version": "0.1.0",
  "description": "Tauri + Vue desktop AI voice changer based on FunSpeech.",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir frontend dev",
    "build": "pnpm --dir frontend build",
    "preview": "pnpm --dir frontend preview",
    "tauri": "tauri",
    "sidecars:ensure": "node scripts/ensure-sidecars.mjs",
    "sidecars:check": "node scripts/ensure-sidecars.mjs --check",
    "tauri:dev": "pnpm sidecars:ensure && tauri dev",
    "tauri:build": "pnpm sidecars:ensure && tauri build",
    "tauri:android:init": "tauri android init --ci --skip-targets-install",
    "tauri:android:build": "tauri android build --ci --apk true --aab false",
    "tauri:ios:init": "tauri ios init --ci",
    "tauri:ios:build": "tauri ios build --ci --target aarch64-sim"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
